        UI["Chat UI\n• Question input\n• Answer display\n• Intent chip\n• Source cards"]
    end

    subgraph BE["Backend — FastAPI :8000"]
        R1["POST /query"]
        R2["GET /health"]
        R3["GET /documents"]
        R4["GET /documents/view/{filename}"]

        subgraph PIPE["Sequential RAG Pipeline (LangChain LCEL)"]
            direction TB
            A1["① Query Understanding\n• Intent classification\n• Query reformulation\n• Key entity extraction\n  temp=0"]
            A2["② Search Agent\n• Semantic similarity search\n• Top-K chunk retrieval\n• Score conversion"]
            A3["③ Answer Generator\n• Context-grounded synthesis\n• has_answer detection\n  temp=0.3"]
            A4["④ Source Linker\n• Deduplication by source\n• Score-ranked SourceLinks"]
            A1 --> A2 --> A3 --> A4
        end
    end

    subgraph DATA["Data Layer"]
        VDB[("ChromaDB\n(persistent on-disk)\ncollection: knowledge_base\n35 chunks / 8 docs")]
        FS[("Document Store\ndata/sample_docs/\n8 × Markdown files")]
    end

    subgraph LLM["LLM Provider — LiteLLM Proxy"]
        GEN["gemini-2.5-flash\n(answer generation)"]
        EMB["text-embedding-3-large\n(embeddings)"]
    end

    subgraph INGEST["Ingestion (offline — scripts/ingest.py)"]
