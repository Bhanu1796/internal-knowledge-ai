    UI -->|"GET /health\nGET /documents"| R2
    UI -->|"GET /documents"| R3

    R1 --> PIPE
    A2 -->|"similarity_search"| VDB
    A3 -->|"LLM call"| GEN
    A1 -->|"LLM call"| GEN

    R4 -->|"serve file"| FS
    VDB -.->|"metadata: doc_url"| R4

    EMB2 -->|"embed + persist"| VDB
    EMB2 -->|"embed query"| EMB
    FS -->|"load .md files"| DL
